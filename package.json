{
  "name": "backlog-github-sync",
  "version": "1.0.0",
  "description": "One-way sync from Nulab Backlog to GitHub Projects V2",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
