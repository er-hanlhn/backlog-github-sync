    "typecheck": "tsc --noEmit"
  },
  "keywords": ["backlog", "github", "sync", "projects"],
  "license": "MIT",
  "dependencies": {
    "@octokit/graphql": "^8.0.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "typescript": "^5.5.0"
  }
}
